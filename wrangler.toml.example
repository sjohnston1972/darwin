name = "darwin-api"
main = "workers/api/src/index.ts"
compatibility_date = "2026-07-01"

[vars]
DARWIN_AI_MODE = "mock"
OPENAI_MODEL = "gpt-5.6"
OPENAI_LAB_AGENT_MODEL = "gpt-5.6-luna"
DARWIN_DEMO_SEED = "1859"
DARWIN_EVENT_COUNT = "10000"
DARWIN_REPOSITORY_COMMIT = "REPLACE_WITH_GIT_SHA"
PROJECTFLOW_REPOSITORY = "sjohnston1972/projectflow"
PROJECTFLOW_BRANCH = "main"
PROJECTFLOW_PRODUCTION_URL = "https://darwin-projectflow.pages.dev/"
PROJECTFLOW_STUDY_URL = "https://darwin-projectflow.pages.dev/?study=true"
PROJECTFLOW_LAB_STUDY_ID = "projectflow-darwin-lab"
DARWIN_LAB_ALLOWED_ORIGINS = "http://localhost:5174,http://127.0.0.1:5174"
ALLOWED_ORIGINS = "https://darwin-control-room.pages.dev,https://darwin-projectflow.pages.dev,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174"

# Create and bind after initial deployment:
[[d1_databases]]
binding = "DB"
database_name = "darwin-telemetry"
database_id = "REPLACE_ME"
migrations_dir = "workers/api/migrations"

[[ratelimits]]
name = "INGESTION_RATE_LIMITER"
namespace_id = "REPLACE_WITH_POSITIVE_INTEGER"

[ratelimits.simple]
limit = 120
period = 60
