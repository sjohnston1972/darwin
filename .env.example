# Darwin local environment
DARWIN_AI_MODE=live
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_LAB_AGENT_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT_MS=45000
GITHUB_TOKEN=
DARWIN_CALLBACK_TOKEN=
DARWIN_OPERATOR_TOKEN=
# Optional read-only credential for connection status and aggregate telemetry.
DARWIN_VIEWER_TOKEN=
# Must match the Cloudflare Pages secret on the ProjectFlow project.
PROJECTFLOW_INGESTION_SECRET=
PROJECTFLOW_ALLOWED_APP_VERSIONS=baseline,1.0.0
DARWIN_DEMO_SEED=1859
DARWIN_EVENT_COUNT=10000
PROJECTFLOW_LAB_STUDY_ID=projectflow-darwin-lab
DARWIN_LAB_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
DARWIN_REPOSITORY_COMMIT=working-tree
VITE_API_BASE_URL=http://localhost:8787
VITE_PROJECTFLOW_BASE_URL=http://localhost:5174
# Optional override; defaults to VITE_API_BASE_URL/api/telemetry/events.
VITE_TELEMETRY_ENDPOINT=
