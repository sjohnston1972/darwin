{
  "name": "darwin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Darwin - helping your software evolve.",
  "workspaces": [
    "packages/*",
    "workers/*",
    "apps/*"
  ],
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "dev": "concurrently -n api,darwin -c green,cyan \"npm run dev -w @darwin/api\" \"npm run dev -w @darwin/web\"",
    "simulate": "npm run simulate -w @darwin/api --",
    "context:generate": "node scripts/generate-reasoning-context.mjs",
    "context:check": "node scripts/generate-reasoning-context.mjs --check",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,html,json}\" \"workers/**/*.{ts,json}\" \"packages/**/*.{ts,json}\" \"*.{json,js}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,html,json}\" \"workers/**/*.{ts,json}\" \"packages/**/*.{ts,json}\" \"*.{json,js}\"",
    "typecheck": "npm run context:check && npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "build": "node scripts/build.mjs",
    "deploy:migrate": "wrangler d1 migrations apply darwin-telemetry --remote --config workers/api/wrangler.toml",
    "deploy:api": "wrangler deploy --config workers/api/wrangler.toml",
    "deploy:web": "wrangler pages deploy apps/web/dist --project-name=darwin-control-room --branch=main",
    "deploy": "node scripts/deploy.mjs",
    "smoke:production": "tsx scripts/smoke-production.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  }
}
